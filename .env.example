# Prepio - Environment Variables
# Copy this file to .env.local and fill in your values.
#
# Only actual secrets and per-environment values belong here.
# App config (models, timeouts, feature flags) lives in code:
#   supabase/functions/_shared/config.ts

# =============================================================================
# FRONTEND (exposed to the browser via Vite)
# =============================================================================

# Supabase project URL and publishable (anon) key
# Found in: Supabase Dashboard -> Settings -> API Keys
VITE_SUPABASE_URL=https://vjwrirrqprjzdorignlz.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# =============================================================================
# SUPABASE EDGE FUNCTIONS (set as secrets in Supabase Dashboard)
# =============================================================================

# Supabase connection (edge functions create their own admin client)
SUPABASE_URL=https://vjwrirrqprjzdorignlz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OpenAI — used for all research analysis steps
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Tavily — used for web search and content extraction
# Get from: https://tavily.com
TAVILY_API_KEY=tvly-...

# Optional: override the default model for all operations (default: gpt-4o)
# OPENAI_MODEL=gpt-4o
